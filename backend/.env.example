# ── Server ────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB Atlas (DBaaS) ─────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/codex?retryWrites=true&w=majority

# ── JWT (Security as a Service) ───────────────
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Cloudinary (Storage as a Service) ─────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
